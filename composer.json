{
    "name": "dev-karunendu-mishra/devfoxx-laravel-admin-panel",
    "description": "Reusable Laravel admin panel package with gallery management and React/Inertia runtime UI.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "admin-panel",
        "gallery",
        "react",
        "inertia"
    ],
    "homepage": "https://github.com/dev-karunendu-mishra/devfoxx-laravel-admin-panel",
    "authors": [
        {
            "name": "DevFoxx",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/dev-karunendu-mishra/devfoxx-laravel-admin-panel/issues",
        "source": "https://github.com/dev-karunendu-mishra/devfoxx-laravel-admin-panel"
    },
    "require": {
        "php": "^8.2",
        "illuminate/auth": "^11.0|^12.0",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/filesystem": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/routing": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/view": "^11.0|^12.0",
        "inertiajs/inertia-laravel": "^2.0",
        "spatie/laravel-permission": "^6.0",
        "tightenco/ziggy": "^2.0"
    },
    "require-dev": {
        "laravel/pint": "^1.13",
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "DevFoxx\\AdminPanel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DevFoxx\\AdminPanel\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "format": "vendor/bin/pint"
    },
    "extra": {
        "laravel": {
            "providers": [
                "DevFoxx\\AdminPanel\\AdminPanelServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "1.x-dev"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
